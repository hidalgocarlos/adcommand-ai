generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  role          Role     @default(OPERATOR)
  passwordHash  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  workspaces    WorkspaceMember[]
  auditLogs     AuditLog[]
}

enum Role { 
  ADMIN 
  OPERATOR 
  VIEWER 
}

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  members     WorkspaceMember[]
  connections AdConnection[]
  campaigns   Campaign[]
  aiKeys      AiKeyConfig[]
  createdAt   DateTime @default(now())
}

model WorkspaceMember {
  userId      String
  workspaceId String
  role        String   @default("OPERATOR")
  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  @@id([userId, workspaceId])
}

model AdConnection {
  id              String   @id @default(cuid())
  workspaceId     String
  platform        String   @default("META")
  name            String?
  accessToken     String   // AES-256 encrypted
  adAccountId     String
  adAccountName   String?
  status          String   @default("ACTIVE")
  lastSyncAt      DateTime?
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  campaigns       Campaign[]
}

model AiKeyConfig {
  id              String   @id @default(cuid())
  workspaceId     String
  provider        String   // "OPENAI", "ANTHROPIC", "GOOGLE"
  apiKey          String   // AES-256 encrypted
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  @@unique([workspaceId, provider])
}

model Campaign {
  id              String   @id @default(cuid())
  workspaceId     String
  connectionId    String
  externalId      String   @unique // Meta Campaign ID
  name            String
  status          String
  objective       String?
  budget          String?
  insights        CampaignInsight[]
  aiAnalyses      AiAnalysis[]
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
  connection      AdConnection @relation(fields: [connectionId], references: [id])
}

model CampaignInsight {
  id              String   @id @default(cuid())
  campaignId      String
  externalId      String?  // Can be used for mapping
  date            DateTime
  spend           Float    @default(0)
  impressions     Int      @default(0)
  clicks          Int      @default(0)
  conversions     Int      @default(0)
  revenue         Float    @default(0)
  campaign        Campaign @relation(fields: [campaignId], references: [id])
  @@unique([campaignId, date])
}

model AiAnalysis {
  id              String   @id @default(cuid())
  campaignId      String
  workspaceId     String
  provider        String
  model           String
  prompt          String   @db.Text
  rawResponse     String   @db.Text
  recommendations Recommendation[]
  score           Int?
  createdAt       DateTime @default(now())
  campaign        Campaign @relation(fields: [campaignId], references: [id])
}

model Recommendation {
  id              String   @id @default(cuid())
  analysisId      String
  type            String
  priority        String
  title           String
  explanation     String   @db.Text
  impact          String
  analysis        AiAnalysis @relation(fields: [analysisId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  entity      String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User @relation(fields: [userId], references: [id])
}
